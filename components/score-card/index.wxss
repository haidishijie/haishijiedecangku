/* 积分卡片样式 */

.score-card {
  display: flex;
  align-items: center;
  padding: 16px;
  border-radius: 20px;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border: 0.5px solid rgba(0,0,0,0.06);
  gap: 12px;
}

.score-card.leading {
  background: linear-gradient(135deg, #007AFF, #5AC8FA);
  border: none;
}

.score-card.leading .name,
.score-card.leading .total-score,
.score-card.leading .round-score {
  color: white;
}

.rank {
  width: 24px;
  text-align: center;
}

.rank-num {
  font-size: 14px;
  font-weight: 700;
  color: #8E8E93;
}

.avatar {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 16px;
  font-weight: 700;
  color: white;
}

.info {
  flex: 1;
}

.name {
  font-size: 17px;
  font-weight: 600;
  color: #1C1C1E;
}

.round-score {
  font-size: 13px;
  font-weight: 500;
  margin-top: 2px;
}

.round-score.positive {
  color: #34C759;
}

.round-score.negative {
  color: #FF3B30;
}

.total {
  text-align: right;
}

.total-score {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -1px;
}

.total-score.positive {
  color: #34C759;
}

.total-score.negative {
  color: #FF3B30;
}
