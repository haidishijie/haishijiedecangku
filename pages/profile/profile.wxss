/* 个人中心样式 */

.container {
  min-height: 100vh;
  padding: 0 20px 40px;
  background: var(--color-background);
}

/* 用户信息 */
.profile-header {
  text-align: center;
  padding: 32px 0 24px;
}

.avatar-btn {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  padding: 0;
  margin: 0 auto 16px;
  background: transparent;
  border: none;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  display: none;
}

.avatar-img {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  border: 3px solid #F4C0D1;
}

.avatar-placeholder {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D, #FF8A80);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 28px;
  margin-bottom: 2px;
}

.avatar-hint {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.9);
}

/* 昵称 */
.nickname-wrap {
  margin-bottom: 8px;
}

.nickname-input {
  font-size: 20px;
  font-weight: 600;
  color: #2C2C2A;
  text-align: center;
  padding: 8px 20px;
  background: #FFFFFF;
  border-radius: 20px;
  border: 1.5px solid #F4C0D1;
  margin: 0 auto;
  max-width: 200px;
}

.user-id {
  font-size: 12px;
  color: #888780;
  margin-top: 4px;
}

/* 战绩统计 */
.stats-section {
  margin-bottom: 24px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #5F5E5A;
  margin-bottom: 12px;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 14px;
}

.stat-item {
  background: #FFFFFF;
  border-radius: 14px;
  padding: 16px;
  text-align: center;
  border: 0.5px solid #F4C0D1;
}

.stat-value {
  font-size: 24px;
  font-weight: 700;
  color: #E24B4A;
  margin-bottom: 2px;
}

.stat-value.positive {
  color: #E24B4A;
}

.stat-value.negative {
  color: #185FA5;
}

.stat-label {
  font-size: 11px;
  color: #888780;
}

/* 胜率 */
.win-rate {
  background: #FFFFFF;
  border-radius: 14px;
  padding: 14px 16px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.rate-bar {
  height: 8px;
  background: #E6F1FB;
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 8px;
}

.rate-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B9D, #FF8A80);
  border-radius: 4px;
  transition: width 0.5s ease;
}

.rate-text {
  font-size: 13px;
  color: #5F5E5A;
  text-align: center;
  font-weight: 500;
}

/* 常见牌友 */
.ranking-section {
  margin-bottom: 24px;
}

.empty-hint {
  text-align: center;
  padding: 20px;
  font-size: 13px;
  color: #888780;
  background: #FFFFFF;
  border-radius: 14px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.opponent-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 14px;
  padding: 12px 16px;
  margin-bottom: 8px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.opponent-rank {
  width: 24px;
  font-size: 14px;
  font-weight: 600;
  color: #888780;
  text-align: center;
  margin-right: 8px;
}

.opponent-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
  margin-right: 10px;
  flex-shrink: 0;
}

.opponent-info {
  flex: 1;
}

.opponent-name {
  font-size: 14px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 1px;
}

.opponent-stats {
  font-size: 11px;
  color: #888780;
}

.opponent-score {
  font-size: 16px;
  font-weight: 700;
}

.opponent-score.positive {
  color: #E24B4A;
}

.opponent-score.negative {
  color: #185FA5;
}

/* 牌友头像颜色类（替换内联8位hex，兼容所有设备） */
.opponent-avatar-0 {
  background: rgba(0, 122, 255, 0.08);
  color: #007AFF;
}

.opponent-avatar-1 {
  background: rgba(52, 199, 89, 0.08);
  color: #34C759;
}

.opponent-avatar-2 {
  background: rgba(175, 82, 222, 0.08);
  color: #AF52DE;
}

.opponent-avatar-3 {
  background: rgba(255, 149, 0, 0.08);
  color: #FF9500;
}

/* 设置 */
.settings-section {
  margin-bottom: 24px;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 8px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.setting-item:active {
  background: #FAECE7;
}

.setting-label {
  font-size: 14px;
  color: #2C2C2A;
}

.setting-arrow {
  font-size: 18px;
  color: #D3D1C7;
}

/* 关于 */
.about-section {
  text-align: center;
  padding: 20px 0;
}

.about-text {
  font-size: 13px;
  color: #888780;
  margin-bottom: 2px;
}

.about-desc {
  font-size: 12px;
  color: #B4B2A9;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  padding: 16px;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border-radius: 16px;
  margin-bottom: 8px;
  border: 0.5px solid rgba(0,0,0,0.06);
}

.setting-label {
  flex: 1;
  font-size: 17px;
  font-weight: 500;
  color: #1C1C1E;
}

.setting-value {
  font-size: 15px;
  color: #8E8E93;
  margin-right: 8px;
}

.setting-arrow {
  font-size: 18px;
  color: #C7C7CC;
}

/* 主题弹窗 */
.theme-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.theme-modal.show {
  opacity: 1;
  visibility: visible;
}

.theme-modal-content {
  width: 100%;
  background: #F2F2F7;
  border-radius: 24px 24px 0 0;
  padding: 24px 20px;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.3s;
}

.theme-modal.show .theme-modal-content {
  transform: translateY(0);
}

.theme-modal-title {
  font-size: 20px;
  font-weight: 700;
  color: #1C1C1E;
  text-align: center;
  margin-bottom: 20px;
}

.theme-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.theme-item {
  display: flex;
  align-items: center;
  padding: 16px;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  border-radius: 16px;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.theme-item.active {
  border-color: #007AFF;
}

.theme-icon {
  font-size: 28px;
  margin-right: 14px;
}

.theme-info {
  flex: 1;
}

.theme-name {
  font-size: 17px;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 6px;
}

.theme-preview {
  display: flex;
  gap: 6px;
}

.preview-dot {
  width: 16px;
  height: 16px;
  border-radius: 50%;
}

.theme-check {
  font-size: 20px;
  font-weight: 700;
  color: #007AFF;
}
