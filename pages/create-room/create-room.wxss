/* 创建房间样式 */

.container {
  min-height: 100vh;
  padding: 0 20px 40px;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFFFFF 25%);
}

.page-header {
  padding: 32px 0 24px;
  text-align: center;
}

.page-title {
  font-size: 24px;
  font-weight: 700;
  color: #2C2C2A;
  margin-bottom: 8px;
}

.page-desc {
  font-size: 14px;
  color: #888780;
}

/* 模式选择 */
.mode-section {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-top: 16px;
}

.mode-card {
  background: #FFFFFF;
  border-radius: 20px;
  padding: 24px;
  text-align: center;
  border: 2px solid transparent;
  transition: all 0.2s;
  box-shadow: 0 2px 12px rgba(255, 107, 157, 0.08);
}

.mode-card:active {
  transform: scale(0.97);
  border-color: #FF6B9D;
  background: #FFF0F5;
}

.mode-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.mode-name {
  font-size: 20px;
  font-weight: 700;
  color: #2C2C2A;
  margin-bottom: 8px;
}

.mode-desc {
  font-size: 14px;
  color: #5F5E5A;
  margin-bottom: 6px;
}

.mode-detail {
  font-size: 12px;
  color: #888780;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40px 0;
}

.loading-icon {
  font-size: 48px;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.loading-text {
  font-size: 16px;
  color: #5F5E5A;
  margin-top: 12px;
}
