<!-- 创建房间 -->
<view class="container">
  <view class="page-header">
    <view class="page-title">🏠 创建房间</view>
    <view class="page-desc">选择模式，开始牌局</view>
  </view>

  <!-- 模式选择 -->
  <view class="mode-section">
    <view class="mode-card" bindtap="onCreateRoom" data-mode="collaborative">
      <view class="mode-icon">👥</view>
      <view class="mode-name">协作模式</view>
      <view class="mode-desc">每个人都能记分，谁手快谁记</view>
      <view class="mode-detail">适合大家都在场，各自手机操作</view>
    </view>

    <view class="mode-card" bindtap="onCreateRoom" data-mode="spectator">
      <view class="mode-icon">👁️</view>
      <view class="mode-name">观战模式</view>
      <view class="mode-desc">一人记分，其他人实时看分数</view>
      <view class="mode-detail">适合一个人记分，分享给朋友看</view>
    </view>
  </view>

  <!-- 创建中 -->
  <view wx:if="{{creating}}" class="loading-state">
    <view class="loading-icon">🀄</view>
    <view class="loading-text">创建中...</view>
  </view>
</view>
