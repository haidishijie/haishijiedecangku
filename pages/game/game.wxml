<!-- 记分页 -->

<!-- 分享落地页内容（从朋友圈打开时显示） -->
<view wx:if="{{showSharePage}}" class="share-container">
  <view class="share-hero">
    <view class="share-hero-emoji">🀄</view>
    <view class="share-hero-title">胡乐麻</view>
    <view class="share-hero-subtitle">打牌记分小程序</view>
  </view>

  <view class="share-features">
    <view class="share-feature-item">
      <view class="share-feature-icon">⚡</view>
      <view class="share-feature-text">
        <view class="share-feature-title">多人实时记分</view>
        <view class="share-feature-desc">支持 2-8 人同时记分，告别算账烦恼</view>
      </view>
    </view>
    <view class="share-feature-item">
      <view class="share-feature-icon">📊</view>
      <view class="share-feature-text">
        <view class="share-feature-title">战绩排行榜</view>
        <view class="share-feature-desc">按月/季/年统计，看看谁是雀神</view>
      </view>
    </view>
    <view class="share-feature-item">
      <view class="share-feature-icon">📋</view>
      <view class="share-feature-text">
        <view class="share-feature-title">历史记录查询</view>
        <view class="share-feature-desc">逐轮详情、胜负统计，一目了然</view>
      </view>
    </view>
    <view class="share-feature-item">
      <view class="share-feature-icon">🎲</view>
      <view class="share-feature-text">
        <view class="share-feature-title">趣味工具箱</view>
        <view class="share-feature-desc">幸运大转盘、疯狂骰子，聚会必备</view>
      </view>
    </view>
  </view>

  <!-- 核心承诺 -->
  <view class="share-promises">
    <view class="share-promise-badge">
      <view class="share-promise-label">永久免费</view>
      <view class="share-promise-desc">所有功能完全免费，无任何付费门槛</view>
    </view>
    <view class="share-promise-badge">
      <view class="share-promise-label">零广告</view>
      <view class="share-promise-desc">干净清爽，专注记分体验</view>
    </view>
  </view>

  <view class="share-cta">
    <button class="share-btn-open" bindtap="onGoHome">立即开局</button>
  </view>

  <view class="share-credit">
    <view class="share-credit-divider"></view>
    <view class="share-credit-text">本内容由 <text class="share-credit-bold">海鲜 Vibe Coding</text> 产出，借助 <text class="share-credit-bold">WorkBuddy</text> 平台协作完成</view>
    <view class="share-credit-models">所使用模型包括：小米 MiMo V2.5 Pro、DeepSeek V4 Flash / Pro、GLM-5.1</view>
  </view>
</view>

<!-- 正常记分内容 -->
<view wx:else class="container">
  <!-- 顶部状态栏 -->
  <view class="game-header">
    <view class="round-info">🀄 第 {{currentRound}} 轮</view>
    <view class="player-names">{{playerNamesStr}}</view>
  </view>

  <!-- 实时积分面板 -->
  <view class="score-board">
    <view
      wx:for="{{players}}"
      wx:key="id"
      class="score-card {{item.total > 0 ? 'positive' : item.total < 0 ? 'negative' : 'zero'}}"
      bindtap="onSelectPlayer"
      data-index="{{index}}"
    >
      <view class="score-name">{{item.name}}</view>
      <view class="score-value">{{item.total > 0 ? '+' : ''}}{{item.total}}</view>
      <view class="score-round" wx:if="{{item.roundPending !== 0}}">
        本轮 {{item.roundPending > 0 ? '+' : ''}}{{item.roundPending}}
      </view>
      <view class="score-last" wx:elif="{{item.lastRound !== 0}}">
        上轮 {{item.lastRound > 0 ? '+' : ''}}{{item.lastRound}}
      </view>
      <view class="score-last" wx:else>上轮 --</view>
    </view>
  </view>

  <!-- 快捷记分区域 -->
  <view class="quick-score-section">
    <view class="quick-score-header">
      <text class="quick-score-title">⚡ 快捷记分</text>
      <text class="quick-score-hint">先选玩家，再点分数</text>
    </view>
    <!-- 玩家选择 -->
    <view class="player-selector">
      <view
        wx:for="{{players}}"
        wx:key="id"
        class="player-chip {{selectedIndex === index ? 'selected' : ''}}"
        bindtap="onSelectPlayer"
        data-index="{{index}}"
      >
        {{item.name}}
      </view>
    </view>

    <!-- 加分按钮 -->
    <view class="score-row">
      <view class="score-btn plus-1" bindtap="onQuickScore" data-score="1">+1</view>
      <view class="score-btn plus-5" bindtap="onQuickScore" data-score="5">+5</view>
      <view class="score-btn plus-8" bindtap="onQuickScore" data-score="8">+8</view>
      <view class="score-btn plus-10" bindtap="onQuickScore" data-score="10">+10</view>
    </view>

    <!-- 减分按钮 -->
    <view class="score-row">
      <view class="score-btn minus-1" bindtap="onQuickScore" data-score="-1">-1</view>
      <view class="score-btn minus-5" bindtap="onQuickScore" data-score="-5">-5</view>
      <view class="score-btn minus-8" bindtap="onQuickScore" data-score="-8">-8</view>
      <view class="score-btn minus-10" bindtap="onQuickScore" data-score="-10">-10</view>
    </view>
  </view>

  <!-- 快速输入 -->
  <view class="quick-input-section">
    <view class="quick-input-header">
      <text class="quick-input-title">💬 快速输入</text>
      <text class="quick-input-hint">语音或手动输入</text>
    </view>
    <view class="quick-input-wrap">
      <input
        class="quick-input-field"
        placeholder="1加5分2减5分 或 小明加5"
        value="{{quickInput}}"
        bindinput="onQuickInput"
        bindconfirm="onQuickSubmit"
        confirm-type="done"
      />
      <view class="btn-quick-submit {{quickInput ? 'active' : ''}}" bindtap="onQuickSubmit">记分</view>
    </view>
    <view class="quick-input-tags">
      <view class="qtag" wx:for="{{players}}" wx:key="id" wx:for-index="idx">
        {{idx + 1}}号={{item.name}}
      </view>
    </view>
  </view>

  <!-- 本轮记录 -->
  <view class="round-records" wx:if="{{currentRoundScores.length > 0}}">
    <view class="records-header">
      <text class="records-title">本轮已记</text>
      <text class="records-count">{{currentRoundScores.length}} 笔</text>
    </view>
    <view class="records-list">
      <view wx:for="{{currentRoundScores}}" wx:key="index" class="record-item">
        <view class="record-name" style="color: {{playerColors[item.playerIndex]}}">{{item.playerName}}</view>
        <view class="record-score {{item.score > 0 ? 'positive' : 'negative'}}">
          {{item.score > 0 ? '+' : ''}}{{item.score}}
        </view>
      </view>
    </view>
  </view>

  <!-- 历史轮次（最近4轮） -->
  <view class="history-section" wx:if="{{roundHistory.length > 0}}">
    <view class="history-header">
      <text class="history-title">📋 历史轮次</text>
      <text class="history-hint">最近4轮</text>
    </view>
    <view wx:for="{{roundHistory}}" wx:key="roundNumber" class="history-round">
      <view class="history-round-title">第 {{item.roundNumber}} 轮</view>
      <view class="history-round-scores">
        <view wx:for="{{item.scores}}" wx:for-item="score" wx:key="playerId" class="history-score-item">
          <text class="hs-name">{{score.playerName}}</text>
          <text class="hs-score {{score.score > 0 ? 'positive' : 'negative'}}">{{score.score > 0 ? '+' : ''}}{{score.score}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions safe-bottom">
    <button class="btn-round" bindtap="onConfirmRound">
      ✅ 确认本轮
    </button>
    <button class="btn-end" bindtap="onEndGame">
      结束牌局
    </button>
  </view>
</view>
