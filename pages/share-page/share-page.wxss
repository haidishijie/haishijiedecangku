/* 分享落地页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFFFFF 25%);
  padding: 0 24px 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头部 */
.hero {
  text-align: center;
  padding: 60px 0 40px;
}

.hero-emoji {
  font-size: 72px;
  margin-bottom: 12px;
}

.hero-title {
  font-size: 32px;
  font-weight: 800;
  color: #E24B4A;
  margin-bottom: 6px;
  letter-spacing: 2px;
}

.hero-subtitle {
  font-size: 15px;
  color: #888780;
  font-weight: 500;
}

.hero-credit {
  font-size: 11px;
  color: #AAA;
  line-height: 1.8;
  margin-top: 16px;
}

.hero-credit-bold {
  font-weight: 600;
  color: #888;
}

.hero-credit-models {
  font-size: 10px;
  color: #CCC;
  line-height: 1.6;
  margin-top: 4px;
}

/* 功能亮点 */
.features {
  width: 100%;
  max-width: 360px;
  margin-bottom: 40px;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 16px;
  padding: 18px 20px;
  margin-bottom: 12px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
}

.feature-icon {
  font-size: 28px;
  margin-right: 14px;
  flex-shrink: 0;
  line-height: 1;
  padding-top: 2px;
}

.feature-text {
  flex: 1;
}

.feature-title {
  font-size: 15px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 3px;
}

.feature-desc {
  font-size: 12px;
  color: #888780;
  line-height: 1.5;
}

/* 核心承诺 */
.promises {
  width: 100%;
  max-width: 360px;
  display: flex;
  gap: 10px;
  margin-bottom: 32px;
}

.promise-badge {
  flex: 1;
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border: 1.5px solid #F4C0D1;
  border-radius: 12px;
  padding: 12px 10px;
  text-align: center;
}

.promise-label {
  font-size: 14px;
  font-weight: 800;
  color: #E24B4A;
  margin-bottom: 3px;
  letter-spacing: 1px;
}

.promise-desc {
  font-size: 10px;
  color: #888780;
  line-height: 1.4;
}

/* 打开按钮 */
.cta-section {
  width: 100%;
  max-width: 360px;
  margin-bottom: 48px;
}

.btn-open {
  width: 100% !important;
  background: linear-gradient(135deg, #FF6B9D, #FF8A80) !important;
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 20px !important;
  padding: 18px !important;
  font-size: 18px !important;
  font-weight: 700 !important;
  box-shadow: 0 6px 20px rgba(255, 107, 157, 0.35);
  letter-spacing: 2px;
}

.btn-open::after {
  display: none;
}
