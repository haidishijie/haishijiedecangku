<!-- 结算页 -->

<!-- 分享落地页内容（从朋友圈打开或没有 gameId 时显示） -->
<view wx:if="{{showSharePage}}" class="share-container">
  <view class="share-hero">
    <view class="share-hero-emoji">🀄</view>
    <view class="share-hero-title">胡乐麻</view>
    <view class="share-hero-subtitle">打牌记分小程序</view>
  </view>

  <view class="share-features">
    <view class="share-feature-item">
      <view class="share-feature-icon">⚡</view>
      <view class="share-feature-text">
        <view class="share-feature-title">多人实时记分</view>
        <view class="share-feature-desc">支持 2-8 人同时记分，告别算账烦恼</view>
      </view>
    </view>
    <view class="share-feature-item">
      <view class="share-feature-icon">📊</view>
      <view class="share-feature-text">
        <view class="share-feature-title">战绩排行榜</view>
        <view class="share-feature-desc">按月/季/年统计，看看谁是雀神</view>
      </view>
    </view>
    <view class="share-feature-item">
      <view class="share-feature-icon">📋</view>
      <view class="share-feature-text">
        <view class="share-feature-title">历史记录查询</view>
        <view class="share-feature-desc">逐轮详情、胜负统计，一目了然</view>
      </view>
    </view>
    <view class="share-feature-item">
      <view class="share-feature-icon">🎲</view>
      <view class="share-feature-text">
        <view class="share-feature-title">趣味工具箱</view>
        <view class="share-feature-desc">幸运大转盘、疯狂骰子，聚会必备</view>
      </view>
    </view>
  </view>

  <!-- 核心承诺 -->
  <view class="share-promises">
    <view class="share-promise-badge">
      <view class="share-promise-label">永久免费</view>
      <view class="share-promise-desc">所有功能完全免费，无任何付费门槛</view>
    </view>
    <view class="share-promise-badge">
      <view class="share-promise-label">零广告</view>
      <view class="share-promise-desc">干净清爽，专注记分体验</view>
    </view>
  </view>

  <view class="share-cta">
    <button class="share-btn-open" bindtap="onGoHome">立即开局</button>
  </view>

  <view class="share-credit">
    <view class="share-credit-divider"></view>
    <view class="share-credit-text">本内容由 <text class="share-credit-bold">海鲜 Vibe Coding</text> 产出，借助 <text class="share-credit-bold">WorkBuddy</text> 平台协作完成</view>
    <view class="share-credit-models">所使用模型包括：小米 MiMo V2.5 Pro、DeepSeek V4 Flash / Pro、GLM-5.1</view>
  </view>
</view>

<!-- 未找到牌局数据（分享到其他设备） -->
<view wx:elif="{{gameNotFound}}" class="container">
  <view class="not-found-section">
    <view class="not-found-icon">🎴</view>
    <view class="not-found-title">该牌局数据仅限原设备查看</view>
    <view class="not-found-desc">胡乐麻使用本地存储，战绩仅保存在打牌的那部手机上哦</view>
    <button class="btn-back-home" bindtap="onGoHome">返回首页</button>
  </view>
</view>

<!-- 正常结算内容 -->
<view wx:else class="container">
  <!-- 胜利横幅 -->
  <view class="victory-banner">
    <view class="victory-emoji">🏆</view>
    <view class="victory-title">牌局结束</view>
    <view class="victory-desc">打了 {{roundCount}} 轮 · {{playerCount}} 人局</view>
  </view>

  <!-- 排名 -->
  <view class="ranking-section">
    <view class="section-title">最终排名</view>

    <view wx:for="{{rankings}}" wx:key="playerId" class="rank-item rank-{{index + 1}}">
      <view class="rank-badge">
        <text wx:if="{{index === 0}}">🥇</text>
        <text wx:elif="{{index === 1}}">🥈</text>
        <text wx:elif="{{index === 2}}">🥉</text>
        <text wx:else>{{index + 1}}</text>
      </view>
      <view class="rank-avatar" style="background: rgba(255,255,255,0.85); color: {{playerColors[item.originalIndex]}}">
        {{item.playerName[0]}}
      </view>
      <view class="rank-info">
        <view class="rank-name">{{item.playerName}}</view>
        <view class="rank-rounds">
          赢 {{item.winRounds}} 轮 · 输 {{item.loseRounds}} 轮
        </view>
      </view>
      <view class="rank-score {{item.total > 0 ? 'positive' : item.total < 0 ? 'negative' : ''}}">
        {{item.total > 0 ? '+' : ''}}{{item.total}}
      </view>
    </view>
  </view>

  <!-- 麻将统计 -->
  <view class="mahjong-stats-section">
    <view class="section-title">🀄 麻将统计</view>

    <!-- 最大赢家 / 最大输家 -->
    <view class="stats-pair">
      <view class="stat-card highlight-win">
        <view class="stat-label">🔥 最大赢家</view>
        <view class="stat-player">{{totalStats.maxWinner.playerName}}</view>
        <view class="stat-value positive">+{{totalStats.maxWinner.total}}</view>
      </view>
      <view class="stat-card highlight-lose">
        <view class="stat-label">💨 最大输家</view>
        <view class="stat-player">{{totalStats.maxLoser.playerName}}</view>
        <view class="stat-value negative">{{totalStats.maxLoser.total}}</view>
      </view>
    </view>

    <!-- 每人详细统计 -->
    <view wx:for="{{rankings}}" wx:key="playerId" class="player-stats-card">
      <view class="ps-header">
        <view class="ps-avatar" style="background: {{playerColors[item.originalIndex]}}">{{item.playerName[0]}}</view>
        <view class="ps-name">{{item.playerName}}</view>
        <view class="ps-total {{item.total > 0 ? 'positive' : item.total < 0 ? 'negative' : ''}}">
          {{item.total > 0 ? '+' : ''}}{{item.total}}
        </view>
      </view>
      <view class="ps-grid">
        <view class="ps-item">
          <text class="ps-value">{{item.winRounds}}/{{roundCount}}</text>
          <text class="ps-label">胜率 {{item.winRate}}%</text>
        </view>
        <view class="ps-item">
          <text class="ps-value">{{item.avgScore > 0 ? '+' : ''}}{{item.avgScore}}</text>
          <text class="ps-label">📈 平均每轮</text>
        </view>
        <view class="ps-item">
          <text class="ps-value">{{item.dealerRounds}}次</text>
          <text class="ps-label">🏆 庄</text>
        </view>
        <view class="ps-item">
          <text class="ps-value">{{item.selfDrawCount}}次</text>
          <text class="ps-label">🀄 自摸({{item.selfDrawRate}}%)</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 逐轮详情 -->
  <view class="rounds-section">
    <view class="section-title">逐轮详情</view>

    <view wx:for="{{roundDetails}}" wx:key="roundNumber" class="round-card">
      <view class="round-header">
        <text class="round-num">第 {{item.roundNumber}} 轮</text>
      </view>
      <view class="round-scores">
        <view wx:for="{{item.scores}}" wx:for-item="score" wx:key="playerId" class="round-score-item">
          <view class="rsi-name" style="color: {{playerColors[score.originalIndex]}}">{{score.playerName}}</view>
          <view class="rsi-score {{score.score > 0 ? 'positive' : 'negative'}}">
            {{score.score > 0 ? '+' : ''}}{{score.score}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions safe-bottom">
    <button class="btn-share" bindtap="onShare">
      📤 分享战绩
    </button>
    <button class="btn-home" bindtap="onGoHome">
      回到首页
    </button>
  </view>
</view>

<!-- 隐藏的 canvas 用于生成分享图 -->
<canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>
