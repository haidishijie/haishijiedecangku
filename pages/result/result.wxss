/* 结算页样式 */

.container {
  min-height: 100vh;
  padding: 0 20px 120px;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFFFFF 30%);
}

/* 未找到牌局 */
.not-found-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100px 20px;
  text-align: center;
}

.not-found-icon {
  font-size: 64px;
  margin-bottom: 20px;
}

.not-found-title {
  font-size: 16px;
  font-weight: 500;
  color: #2C2C2A;
  margin-bottom: 10px;
}

.not-found-desc {
  font-size: 13px;
  color: #888780;
  line-height: 1.6;
  margin-bottom: 30px;
}

.btn-back-home {
  width: 200px;
  background: linear-gradient(135deg, #FF6B9D, #FF8A80) !important;
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 16px !important;
  padding: 14px !important;
  font-size: 15px !important;
  font-weight: 600 !important;
}

/* 胜利横幅 */
.victory-banner {
  text-align: center;
  padding: 32px 0 24px;
}

.victory-emoji {
  font-size: 56px;
  margin-bottom: 8px;
}

.victory-title {
  font-size: 24px;
  font-weight: 700;
  color: #E24B4A;
  margin-bottom: 4px;
}

.victory-desc {
  font-size: 13px;
  color: #888780;
}

/* 排名 */
.ranking-section {
  margin-bottom: 24px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #5F5E5A;
  margin-bottom: 12px;
}

.rank-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 8px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.rank-item.rank-1 {
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border-color: #F4C0D1;
}

.rank-badge {
  width: 32px;
  font-size: 22px;
  text-align: center;
  margin-right: 10px;
}

.rank-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 600;
  margin-right: 12px;
}

.rank-info {
  flex: 1;
}

.rank-name {
  font-size: 15px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 2px;
}

.rank-rounds {
  font-size: 12px;
  color: #888780;
}

.rank-score {
  font-size: 22px;
  font-weight: 700;
}

.rank-score.positive {
  color: #E24B4A;
}

.rank-score.negative {
  color: #185FA5;
}

/* 逐轮详情 */
.rounds-section {
  margin-bottom: 24px;
}

.round-card {
  background: #FFFFFF;
  border-radius: 14px;
  padding: 14px 16px;
  margin-bottom: 8px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.round-header {
  margin-bottom: 10px;
}

.round-num {
  font-size: 14px;
  font-weight: 600;
  color: #5F5E5A;
}

.round-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.round-score-item {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  background: #F1EFE8;
  border-radius: 20px;
  font-size: 13px;
}

.rsi-name {
  font-weight: 500;
}

.rsi-score.positive {
  color: #E24B4A;
  font-weight: 600;
}

.rsi-score.negative {
  color: #185FA5;
  font-weight: 600;
}

/* 麻将统计 */
.mahjong-stats-section {
  margin-bottom: 24px;
}

.stats-pair {
  display: flex;
  gap: 10px;
  margin-bottom: 16px;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  text-align: center;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.stat-card.highlight-win {
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border-color: #F4C0D1;
}

.stat-card.highlight-lose {
  background: linear-gradient(135deg, #E8F0FE, #D6E8F7);
  border-color: #B5D4F4;
}

.stat-label {
  font-size: 12px;
  color: #888780;
  margin-bottom: 6px;
}

.stat-player {
  font-size: 16px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 4px;
}

.stat-value.positive {
  font-size: 20px;
  font-weight: 700;
  color: #E24B4A;
}

.stat-value.negative {
  font-size: 20px;
  font-weight: 700;
  color: #185FA5;
}

.player-stats-card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 10px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.ps-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 0.5px solid rgba(211, 209, 199, 0.3);
}

.ps-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 10px;
}

.ps-name {
  flex: 1;
  font-size: 15px;
  font-weight: 600;
  color: #2C2C2A;
}

.ps-total {
  font-size: 20px;
  font-weight: 700;
}

.ps-total.positive {
  color: #E24B4A;
}

.ps-total.negative {
  color: #185FA5;
}

.ps-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.ps-item {
  text-align: center;
}

.ps-value {
  display: block;
  font-size: 16px;
  font-weight: 700;
  color: #2C2C2A;
  margin-bottom: 2px;
}

.ps-label {
  display: block;
  font-size: 10px;
  color: #888780;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 20px;
  background: #FFFFFF;
  border-top: 0.5px solid rgba(211, 209, 199, 0.5);
  display: flex;
  gap: 10px;
}

.btn-share {
  flex: 2;
  background: linear-gradient(135deg, #FF6B9D, #FF8A80) !important;
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 16px !important;
  padding: 16px !important;
  font-size: 16px !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 12px rgba(255, 107, 157, 0.3);
}

.btn-share::after {
  display: none;
}

.btn-home {
  flex: 1;
  background: transparent !important;
  color: #5F5E5A !important;
  border: 0.5px solid #D3D1C7 !important;
  border-radius: 16px !important;
  padding: 16px !important;
  font-size: 14px !important;
}

.btn-home::after {
  display: none;
}

/* 隐藏的 canvas — opacity:0 但保留在渲染流中 */
.share-canvas {
  position: fixed;
  left: 0;
  top: 0;
  width: 375px;
  height: 2000px;
  opacity: 0;
  pointer-events: none;
  z-index: -1;
}

/* 分享落地页样式（从朋友圈打开时显示） */
.share-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFFFFF 25%);
  padding: 0 24px 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-hero {
  text-align: center;
  padding: 60px 0 40px;
}

.share-hero-emoji {
  font-size: 72px;
  margin-bottom: 12px;
}

.share-hero-title {
  font-size: 32px;
  font-weight: 800;
  color: #E24B4A;
  margin-bottom: 6px;
  letter-spacing: 2px;
}

.share-hero-subtitle {
  font-size: 15px;
  color: #888780;
  font-weight: 500;
}

.share-features {
  width: 100%;
  max-width: 360px;
  margin-bottom: 40px;
}

.share-feature-item {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 16px;
  padding: 18px 20px;
  margin-bottom: 12px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
}

.share-feature-icon {
  font-size: 28px;
  margin-right: 14px;
  flex-shrink: 0;
  line-height: 1;
  padding-top: 2px;
}

.share-feature-text {
  flex: 1;
}

.share-feature-title {
  font-size: 15px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 3px;
}

.share-feature-desc {
  font-size: 12px;
  color: #888780;
  line-height: 1.5;
}

.share-cta {
  width: 100%;
  max-width: 360px;
  margin-bottom: 48px;
}

.share-btn-open {
  width: 100% !important;
  background: linear-gradient(135deg, #FF6B9D, #FF8A80) !important;
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 20px !important;
  padding: 18px !important;
  font-size: 18px !important;
  font-weight: 700 !important;
  box-shadow: 0 6px 20px rgba(255, 107, 157, 0.35);
  letter-spacing: 2px;
}

.share-btn-open::after {
  display: none;
}

/* 核心承诺 */
.share-promises {
  width: 100%;
  max-width: 360px;
  display: flex;
  gap: 12px;
  margin-bottom: 32px;
}

.share-promise-badge {
  flex: 1;
  background: linear-gradient(135deg, #FFF0F5, #FFE4EC);
  border: 1.5px solid #F4C0D1;
  border-radius: 16px;
  padding: 20px 16px;
  text-align: center;
}

.share-promise-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.share-promise-label {
  font-size: 18px;
  font-weight: 800;
  color: #E24B4A;
  margin-bottom: 4px;
  letter-spacing: 1px;
}

.share-promise-desc {
  font-size: 11px;
  color: #888780;
  line-height: 1.5;
}

.share-credit {
  width: 100%;
  max-width: 360px;
  text-align: center;
  padding-top: 8px;
}

.share-credit-divider {
  width: 60px;
  height: 2px;
  background: #E0E0E0;
  margin: 0 auto 16px;
  border-radius: 1px;
}

.share-credit-text {
  font-size: 11px;
  color: #AAA;
  line-height: 1.8;
  margin-bottom: 6px;
}

.share-credit-bold {
  font-weight: 600;
  color: #888;
}

.share-credit-models {
  font-size: 10px;
  color: #CCC;
  line-height: 1.6;
}
