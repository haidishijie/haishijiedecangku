/* 加入房间样式 */

.container {
  min-height: 100vh;
  padding: 0 20px 40px;
  background: linear-gradient(180deg, #FFF0F5 0%, #FFFFFF 25%);
}

.page-header {
  padding: 24px 0 20px;
}

.page-title {
  font-size: 22px;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 4px;
}

.page-desc {
  font-size: 13px;
  color: #888780;
}

/* 房间号输入 */
.code-section {
  margin-bottom: 24px;
}

.code-title {
  font-size: 14px;
  font-weight: 600;
  color: #5F5E5A;
  margin-bottom: 12px;
}

.code-input-wrap {
  margin-bottom: 8px;
}

.code-input {
  background: #FFFFFF;
  border: 2px solid #F4C0D1;
  border-radius: 16px;
  padding: 16px;
  font-size: 24px;
  font-weight: 700;
  text-align: center;
  letter-spacing: 8px;
  color: #E24B4A;
}

.code-hint {
  font-size: 12px;
  color: #888780;
  text-align: center;
}

/* 昵称显示 */
.name-section {
  margin-bottom: 28px;
  text-align: center;
}

.name-title {
  font-size: 12px;
  color: #888780;
  margin-bottom: 8px;
}

.name-display {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #FFF0F5;
  border-radius: 24px;
  padding: 10px 20px;
}

.name-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B9D, #FF8A80);
  color: #FFFFFF;
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.name-text {
  font-size: 15px;
  font-weight: 600;
  color: #E24B4A;
}

.name-hint {
  font-size: 12px;
  color: #888780;
  margin-top: 6px;
}

/* 加入按钮 */
.action-section {
  margin-bottom: 32px;
}

.btn-join {
  width: 100%;
  background: linear-gradient(135deg, #FF6B9D, #FF8A80) !important;
  color: #FFFFFF !important;
  border: none !important;
  border-radius: 16px !important;
  padding: 18px !important;
  font-size: 17px !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 12px rgba(255, 107, 157, 0.3);
}

.btn-join::after {
  display: none;
}

.btn-join.disabled {
  background: #D3D1C7 !important;
  box-shadow: none;
}

/* 提示 */
.tips-section {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 18px;
  border: 0.5px solid rgba(211, 209, 199, 0.5);
}

.tips-title {
  font-size: 14px;
  font-weight: 600;
  color: #5F5E5A;
  margin-bottom: 10px;
}

.tips-list {
  padding-left: 4px;
}

.tip-item {
  font-size: 13px;
  color: #888780;
  line-height: 2;
  position: relative;
  padding-left: 12px;
}

.tip-item::before {
  content: '·';
  position: absolute;
  left: 0;
  color: #FF6B9D;
  font-weight: 700;
}
