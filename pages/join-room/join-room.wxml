<!-- 加入房间 -->
<view class="container">
  <view class="page-header">
    <view class="page-title">🚪 加入房间</view>
    <view class="page-desc">输入房间号加入牌局</view>
  </view>

  <!-- 房间号输入 -->
  <view class="code-section">
    <view class="code-title">输入房间号</view>
    <view class="code-input-wrap">
      <input
        class="code-input"
        type="number"
        maxlength="4"
        placeholder="输入4位房间号"
        value="{{roomCode}}"
        bindinput="onInputCode"
        focus="{{true}}"
      />
    </view>
    <view class="code-hint">房间号由创建者分享给你</view>
  </view>

  <!-- 你的昵称 -->
  <view class="name-section">
    <view class="name-title">以以下身份加入</view>
    <view class="name-display" wx:if="{{playerName}}">
      <view class="name-avatar">{{playerName[0]}}</view>
      <text class="name-text">{{playerName}}</text>
    </view>
    <view wx:else>
      <view class="name-display">
        <text class="name-text">未设置昵称</text>
      </view>
      <view class="name-hint">请先去个人中心设置</view>
    </view>
  </view>

  <!-- 加入按钮 -->
  <view class="action-section">
    <button class="btn-join {{canJoin ? '' : 'disabled'}}" bindtap="onJoinRoom" disabled="{{!canJoin}}">
      🚪 加入房间
    </button>
  </view>

  <!-- 提示 -->
  <view class="tips-section">
    <view class="tips-title">💡 提示</view>
    <view class="tips-list">
      <view class="tip-item">房间号是 4 位数字，由创建者分享</view>
      <view class="tip-item">加入后可以看到实时分数</view>
      <view class="tip-item">协作模式下你也可以记分</view>
    </view>
  </view>
</view>
