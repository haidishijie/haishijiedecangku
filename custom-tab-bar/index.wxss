/* 自定义底部导航栏 - iOS 23 风格 */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 83px;
  background: rgba(255,255,255,0.72);
  backdrop-filter: blur(40px) saturate(180%);
  -webkit-backdrop-filter: blur(40px) saturate(180%);
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  padding-top: 8px;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 0.5px solid rgba(0,0,0,0.08);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 64px;
  padding-top: 4px;
}

.tab-item.active .tab-icon {
  opacity: 1;
}

.tab-item.active .tab-text {
  color: #FF6B6B;
  font-weight: 600;
}

.tab-icon {
  width: 24px;
  height: 24px;
  opacity: 0.5;
  margin-bottom: 2px;
}

.tab-text {
  font-size: 10px;
  color: #8E8E93;
  font-weight: 500;
}

/* 中间开局按钮 */
.tab-item-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 64px;
  margin-top: -20px;
}

.center-btn {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: linear-gradient(135deg, #FF6B6B, #FF8A80);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(255, 107, 107, 0.4);
  transition: transform 0.2s;
}

.center-btn:active {
  transform: scale(0.95);
}

.center-icon {
  width: 32px;
  height: 32px;
}

.center-text {
  margin-top: 4px;
  color: #FF6B6B;
  font-weight: 600;
}
